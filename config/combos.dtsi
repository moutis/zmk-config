COMBO(rbkt,   &kp RBKT,   17 18, DEF BRD,  40)
COMBO(tab,    &kp TAB,    11 13, DEF BRD,  40)
COMBO(del,    &kp DEL,    16 18, DEF BRD,  40)

COMBO(capswd, &caps_word, 13 16, DEF BRD,  60)

COMBO(play,   &kp C_PP,    4 14, NAV,     200)

#ifdef ALPHA_23332
